pipeline{
    agent any
    stages{
        stage("Clone the code"){
            steps{
                echo "Clone the code"
            }
        }
        
        stage("Install the dependiances"){
            steps{
                echo "Install dependiances"
            }
        }

        stage("Scanning the code"){
            steps{
                echo "Scan the code"
            }
        }

        stage("Testing the code") {
            steps{
                echo "Test the code"
            }
        }
        
        stage("Build the Image"){
            steps{
                echo "Build image"
            }
        }
        
        stage("Deploy the Image"){
            steps{
                echo "Deploy image"
            }
        }
    }
}